    "helmet": "^7.1.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.0",
    "sequelize-cli": "^6.6.2",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3"
  }
}